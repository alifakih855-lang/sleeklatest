t in Wien zu schaffen, an dem sich jede Frau wirklich gesehen und vollkommen zu Hause fühlt.<\/p><p>Dank euch ist dieser Traum größer geworden, als wir es uns je vorgestellt hätten. 🤍<\/p><p>Alpen Wien zieht um. 🤍<\/p><p>Ja! Wir eröffnen einen weltweiten Store. Ein größerer, noch schönerer Raum — mit derselben intimen Seele, derselben von Schwestern geschaffenen Liebe, nur mit mehr Platz, damit du an verschiedenen Orten aufatmen und strahlen kannst.<\/p><p>Um unseren Ausverkauf zu beschleunigen, bieten wir Rabatte von bis zu 70 % an.<\/p><p><strong>KAUFE 2 → EXTRA 20 % RABATT<\/strong><\/p><p><strong>KAUFE 3 → EXTRA 25 % RABATT<\/strong><\/p><p><strong>KAUFE 4+ → EXTRA 30 % RABATT<\/strong><\/p><p>Rabatte werden automatisch im Checkout angewendet & Artikel können aus verschiedenen Kollektionen kombiniert werden.<\/p>","text_size":"text-base"}},"button_BUmEkg":{"type":"button","disabled":true,"settings":{"button_label":"Button label","button_link":"","button_style":"btn--primary"}}},"block_order":["heading_9gGPxP","text_WckH8K","button_BUmEkg"],"name":"t:sections.rich-text.presets.name","settings":{"color_scheme":"","content_alignment":"center","padding_top":50,"padding_bottom":50,"show_section_divider":false,"divider_width":"fixed","custom_class":""}},"product-grid":{"type":"main-collection-product-grid","custom_css":[".f-price-item {font-size: 15px;}"],"settings":{"color_scheme":"scheme-1","products_per_page":15,"columns_desktop":3,"grid_layout":"standard","pagination":"number","enable_color_swatch":false,"enable_filtering":false,"filter_type":"vertical","enable_sorting":false,"expand_filter_groups":"Availability, Price, Color, Size, Product type","columns_mobile":"2","padding_top":40,"padding_bottom":100,"show_section_divider":true,"divider_width":"fixed"}}},"order":["breadcrumbs_Gxg9wp","banner","image_with_text_overlay_aEhewx","rich_text_kjVBVk","product-grid"]}